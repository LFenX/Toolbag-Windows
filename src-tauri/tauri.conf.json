{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toolbag",
  "version": "0.1.0",
  "identifier": "com.lfen.toolbag",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Toolbag",
        "label": "main",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "publisher": "LFen",
    "category": "Utility",
    "shortDescription": "Windows local toolkit workbench",
    "longDescription": "Toolbag is a Windows-first local toolkit workbench built with Tauri, Rust, React and TypeScript.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
